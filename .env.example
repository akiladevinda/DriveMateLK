# Client-safe public configuration only.
# Never put Gemini keys or Supabase service-role keys here.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_APP_ENV=development
# Set true only to force text-only mock AI (no edge vision)
# EXPO_PUBLIC_USE_MOCK_AI=true
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_SUPPORT_EMAIL=support@drivematelk.lk
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://drivematelk.lk/privacy
EXPO_PUBLIC_TERMS_URL=https://drivematelk.lk/terms

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (set via `supabase secrets set`, NOT in app)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_TEXT_MODEL=gemini-flash-latest
# GEMINI_VISION_MODEL=gemini-flash-latest
# GOOGLE_PLACES_API_KEY=   # Places Nearby Search for workshop suggestions (optional)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
